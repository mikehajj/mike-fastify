{
  "check-coverage": false,
  "all": true,
  "exclude": [
    "coverage_check.js",
    "app/server.js",
    "app/cli.js",
    "server.js",
    "bin/*",
    "tests/*",
    "tests/coverage/lcov-report/*",
    "app/templates/**"
  ],
  "report-dir": "./tests/coverage/",
  "reporter": [
    "json-summary",
    "text",
    "lcov"
  ]
}